rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /produtos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.perfil == "admin"
        && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.ativo == true
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    // Fotos de receita medica enviadas pelo cliente no checkout. Dado de
    // saude sensivel (LGPD) - so o proprio cliente, admin e farmaceutico RT
    // ativos podem ler; ninguem alem do dono pode escrever ou apagar.
    match /receitas/{uid}/{allPaths=**} {
      allow read: if request.auth != null
        && (
          request.auth.uid == uid
          || (
            firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.ativo == true
            && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.perfil in ["admin", "farmaceutico"]
          )
        );
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if false;
    }
  }
}
